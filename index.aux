\@writefile{toc}{\contentsline {subsubsection}{\nonumberline Exploratory: Speed Sensitivity and HF Component Decomposition}{8}{subsubsection*.13}\protected@file@percent }
\newlabel{exploratory-speed-sensitivity-and-hf-component-decomposition}{{}{8}{Exploratory: Speed Sensitivity and HF Component Decomposition}{subsubsection*.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Exploratory (B1): Subject-level speed sensitivity of dynamical strain (d eta / d speed). Able-bodied subjects cluster near zero, while stroke groups show broader and more positive speed sensitivity.}}{8}{figure.caption.14}\protected@file@percent }
\newlabel{fig-explore-eta-slope}{{3}{8}{Exploratory (B1): Subject-level speed sensitivity of dynamical strain (d eta / d speed). Able-bodied subjects cluster near zero, while stroke groups show broader and more positive speed sensitivity}{figure.caption.14}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Exploratory (C): HF effect-size attenuation as mechanistic components are added sequentially (group+speed, +rank, +eigenvalue distance, +eta). Larger drops indicate greater explanatory contribution of the added component.}}{8}{figure.caption.15}\protected@file@percent }
\newlabel{fig-explore-attenuation}{{4}{8}{Exploratory (C): HF effect-size attenuation as mechanistic components are added sequentially (group+speed, +rank, +eigenvalue distance, +eta). Larger drops indicate greater explanatory contribution of the added component}{figure.caption.15}{}}
\@writefile{toc}{\contentsline {subsubsection}{\nonumberline Figure 3: Harmonic Resolvent Gain Reveals Stroke-Related Collapse of High-Frequency Coupling}{9}{subsubsection*.16}\protected@file@percent }
\newlabel{figure-3-harmonic-resolvent-gain-reveals-stroke-related-collapse-of-high-frequency-coupling}{{}{9}{Figure 3: Harmonic Resolvent Gain Reveals Stroke-Related Collapse of High-Frequency Coupling}{subsubsection*.16}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Absolute and normalised harmonic resolvent gain. (A) Absolute gain at harmonics 1--5. (B) Gain normalised by the fundamental, revealing fall-off shape independent of overall gain level.}}{9}{figure.caption.17}\protected@file@percent }
\newlabel{fig-harmonic-all}{{5}{9}{Absolute and normalised harmonic resolvent gain. (A) Absolute gain at harmonics 1--5. (B) Gain normalised by the fundamental, revealing fall-off shape independent of overall gain level}{figure.caption.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Absolute harmonic gain faceted by walking speed bin (blue = slow, red = fast). Speed modulates the gain profile within each group differently, with AB showing the largest speed-dependent change.}}{9}{figure.caption.18}\protected@file@percent }
\newlabel{fig-harmonic-speed}{{6}{9}{Absolute harmonic gain faceted by walking speed bin (blue = slow, red = fast). Speed modulates the gain profile within each group differently, with AB showing the largest speed-dependent change}{figure.caption.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Speed-matched harmonic gain comparison (AB capped at the maximum HF speed). Group differences in the fall-off shape persist after controlling for speed.}}{10}{figure.caption.19}\protected@file@percent }
\newlabel{fig-harmonic-matched}{{7}{10}{Speed-matched harmonic gain comparison (AB capped at the maximum HF speed). Group differences in the fall-off shape persist after controlling for speed}{figure.caption.19}{}}
