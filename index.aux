\@writefile{toc}{\contentsline {subsubsection}{\nonumberline Figure 2: Speed-Dependent Non-Normality Distinguishes Stroke from Able-Bodied Gait}{7}{subsubsection*.11}\protected@file@percent }
\newlabel{figure-2-speed-dependent-non-normality-distinguishes-stroke-from-able-bodied-gait}{{}{7}{Figure 2: Speed-Dependent Non-Normality Distinguishes Stroke from Able-Bodied Gait}{subsubsection*.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Henrici departure vs walking speed for 299 gait trials. AB = able-bodied (steelblue), HF = high-functioning stroke (orange), LF = low-functioning stroke (crimson). Lines connect trials from the same subject across speeds. The strip chart (right) shows speed-matched comparisons.}}{7}{figure.caption.12}\protected@file@percent }
\newlabel{fig-nonnormality}{{2}{7}{Henrici departure vs walking speed for 299 gait trials. AB = able-bodied (steelblue), HF = high-functioning stroke (orange), LF = low-functioning stroke (crimson). Lines connect trials from the same subject across speeds. The strip chart (right) shows speed-matched comparisons}{figure.caption.12}{}}
