\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Exploratory (A): Group-median resolvent gain curves normalised by each trial's fundamental frequency and gain at the fundamental. Curves that remain elevated at higher f/f\_stride indicate broader frequency responsiveness.}}{11}{figure.caption.21}\protected@file@percent }
\newlabel{fig-explore-resolvent-breadth}{{8}{11}{Exploratory (A): Group-median resolvent gain curves normalised by each trial's fundamental frequency and gain at the fundamental. Curves that remain elevated at higher f/f\_stride indicate broader frequency responsiveness}{figure.caption.21}{}}
