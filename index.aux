\newlabel{fig-explore-gain-rank}{{9}{12}{Exploratory (F1): Fundamental gain normalised by retained operator rank (log10(gain\_h1/rank)), probing concentration of amplification relative to dimensionality}{figure.caption.22}{}}
\@writefile{toc}{\contentsline {subsubsection}{\nonumberline Figure 4: Spatial Resolvent Asymmetry, Q-Factor, and Knee-Centred Coupling Summaries Differentiate Groups}{12}{subsubsection*.23}\protected@file@percent }
\newlabel{figure-4-spatial-resolvent-asymmetry-q-factor-and-knee-centred-coupling-summaries-differentiate-groups}{{}{12}{Figure 4: Spatial Resolvent Asymmetry, Q-Factor, and Knee-Centred Coupling Summaries Differentiate Groups}{subsubsection*.23}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Speed-matched strip charts for the coarse operator metrics. (A) Spatial resolvent asymmetry: ratio of cross-body resolvent norms, max/min. (B) Peak Q-factor at stride frequency. (C) Mean paretic→non-paretic resolvent gain. (D) Mean non-paretic→paretic resolvent gain. Lines show median; error bars show IQR.}}{13}{figure.caption.24}\protected@file@percent }
\newlabel{fig-novel-strips}{{10}{13}{Speed-matched strip charts for the coarse operator metrics. (A) Spatial resolvent asymmetry: ratio of cross-body resolvent norms, max/min. (B) Peak Q-factor at stride frequency. (C) Mean paretic→non-paretic resolvent gain. (D) Mean non-paretic→paretic resolvent gain. Lines show median; error bars show IQR}{figure.caption.24}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Speed-matched summary metrics replacing the full joint-level heatmaps. (E) Knee-target asymmetry, defined as log(hip→non-paretic knee / hip→paretic knee). Positive values indicate that hip-to-knee coupling is concentrated on the non-paretic knee. (F) Non-paretic-knee directional bias, defined as the mean log{[}(hip→non-paretic knee)/(non-paretic knee→hip){]} across both hips. Positive values indicate preferential drive into the non-paretic knee. (G) Global pairwise asymmetry, defined as the mean absolute signed log-ratio across all joint pairs.}}{14}{figure.caption.25}\protected@file@percent }
\newlabel{fig-joint-summary}{{11}{14}{Speed-matched summary metrics replacing the full joint-level heatmaps. (E) Knee-target asymmetry, defined as log(hip→non-paretic knee / hip→paretic knee). Positive values indicate that hip-to-knee coupling is concentrated on the non-paretic knee. (F) Non-paretic-knee directional bias, defined as the mean log{[}(hip→non-paretic knee)/(non-paretic knee→hip){]} across both hips. Positive values indicate preferential drive into the non-paretic knee. (G) Global pairwise asymmetry, defined as the mean absolute signed log-ratio across all joint pairs}{figure.caption.25}{}}
