\@writefile{toc}{\contentsline {subsubsection}{\nonumberline Figure 1: Non-Normality Tracks Nonlinearity and Timescale Separation in Simulated Systems}{5}{subsubsection*.9}\protected@file@percent }
\newlabel{figure-1-non-normality-tracks-nonlinearity-and-timescale-separation-in-simulated-systems}{{}{5}{Figure 1: Non-Normality Tracks Nonlinearity and Timescale Separation in Simulated Systems}{subsubsection*.9}{}}
\BKM@entry{id=10,dest={73756273756273656374696F6E2A2E3131},srcline={508},srcfile={2E2F696E6465782E746578}}{}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Henrici departure in simulated oscillators. (A) Stuart--Landau: Henrici rises with μ as the limit cycle amplitude increases. (B) FitzHugh-Nagumo: Henrici rises as ε decreases and timescale separation strengthens. (C) Stuart--Landau with isochron shear: Henrici rises with shear parameter c.~(D) Henrici heatmap over (μ, c), showing how non-normality grows across joint amplitude-shear settings.}}{6}{figure.caption.10}\protected@file@percent }
\newlabel{fig-simulated}{{1}{6}{Henrici departure in simulated oscillators. (A) Stuart--Landau: Henrici rises with μ as the limit cycle amplitude increases. (B) FitzHugh-Nagumo: Henrici rises as ε decreases and timescale separation strengthens. (C) Stuart--Landau with isochron shear: Henrici rises with shear parameter c.~(D) Henrici heatmap over (μ, c), showing how non-normality grows across joint amplitude-shear settings}{figure.caption.10}{}}
