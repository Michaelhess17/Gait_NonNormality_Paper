    "using LinearAlgebra\n",
    "\n",
    "const HUMAN_DATA_PATH = expanduser(\"/home/michael/Documents/Python/HAVOK/delase/data/all_human_data.npy\")\n",
    "const HUMAN_METADATA_PATH = expanduser(\"/home/michael/Documents/Python/HAVOK/delase/data/all_human_data_metadata.csv\")\n",
    "\n",
    "const N_DELAYS = 40\n",
    "const HANKEL_RANK = 40\n",
    "const GAIN_HORIZON = 10\n",
    "\n",
    "function parse_npy_header(io)\n",
    "    magic = read(io, 6)\n",
    "    magic == UInt8[0x93, UInt8('N'), UInt8('U'), UInt8('M'), UInt8('P'), UInt8('Y')] || error(\"Expected a .npy file\")\n",
    "    major = read(io, UInt8)\n",
    "    _minor = read(io, UInt8)\n",
    "    header_len = major == 1 ? Int(read(io, UInt16)) : Int(read(io, UInt32))\n",
    "    return String(read(io, header_len))\n",
    "end\n",
    "\n",
    "function parse_npy_shape(header)\n",
    "    m = match(r\"'shape': \\(([^\\)]*)\\)\", header)\n",
    "    m === nothing && error(\"Could not find an array shape in the NPY header\")\n",
    "    dims = Int[]\n",
    "    for part in split(strip(m.captures[1]), ',')\n",
    "        s = strip(part)\n",
    "        isempty(s) && continue\n",
    "        push!(dims, parse(Int, s))\n",
    "    end\n",
    "    return Tuple(dims)\n",
    "end\n",
    "\n",
    "function load_npy_float64(path)\n",
    "    open(path, \"r\") do io\n",
    "        header = parse_npy_header(io)\n",
    "        occursin(\"'descr': '<f8'\", header) || error(\"Expected little-endian Float64 data\")\n",
    "        occursin(\"'fortran_order': False\", header) || error(\"Expected a C-order array\")\n",
    "        shape = parse_npy_shape(header)\n",
    "        raw = Array{Float64}(undef, prod(shape))\n",
    "        read!(io, raw)\n",
    "        return permutedims(reshape(raw, reverse(shape)...), reverse(1:length(shape)))\n",
    "    end\n",
    "end\n",
    "\n",
    "function load_metadata(path)\n",
    "    lines = readlines(path)\n",
    "    columns = split(chomp(lines[1]), ',')[2:end]\n",
    "    data = Dict(c => String[] for c in columns)\n",
    "    for line in lines[2:end]\n",
    "        parts = split(chomp(line), ',')\n",
    "        for (column, value) in zip(columns, parts[2:end])\n",
    "            push!(data[column], value)\n",
    "        end\n",
    "    end\n",
    "    return data\n",
    "end\n",
    "\n",
    "mean1(v) = sum(v) / length(v)\n",
    "\n",
    "function std1(v)\n",
    "    μ = mean1(v)\n",
    "    return sqrt(sum((x - μ)^2 for x in v) / (length(v) - 1))\n",
    "end\n",
    "\n",
    "function median1(v)\n",
    "    w = sort(collect(v))\n",
    "    n = length(w)\n",
    "    return isodd(n) ? w[(n + 1) ÷ 2] : (w[n ÷ 2] + w[n ÷ 2 + 1]) / 2\n",
    "end\n",
    "\n",
    "function pearson(x, y)\n",
    "    mx = mean1(x)\n",
    "    my = mean1(y)\n",
    "    dx = x .- mx\n",
    "    dy = y .- my\n",
    "    return sum(dx .* dy) / sqrt(max(sum(dx .* dx) * sum(dy .* dy), 1e-12))\n",
    "end\n",
    "\n",
    "function zscore_trial(X)\n",
    "    Z = Array{Float64}(undef, size(X))\n",
    "    for j in axes(X, 2)\n",
    "        col = view(X, :, j)\n",
    "        μ = mean1(col)\n",
    "        σ = max(std1(col), 1e-8)\n",
    "        @inbounds for i in axes(X, 1)\n",
    "            Z[i, j] = (X[i, j] - μ) / σ\n",
    "        end\n",
    "    end\n",
    "    return Z\n",
    "end\n",
    "\n",
    "function embed_signal(X, n_delays)\n",
    "    T, n = size(X)\n",
    "    rows = T - (n_delays - 1)\n",
    "    H = Matrix{Float64}(undef, rows, n * n_delays)\n",
    "    for d in 1:n_delays\n",
    "        index = n_delays - d\n",
    "        ddelay = d - 1\n",
    "        H[:, (d - 1) * n + 1:d * n] .= @view X[index + 1:T - ddelay, :]\n",
    "    end\n",
    "    return H\n",
    "end\n",
    "\n",
    "function fit_hankel_dmd(X; n_delays=N_DELAYS, rank=HANKEL_RANK, ridge=1e-6)\n",
    "    Z = zscore_trial(X)\n",
    "    H = embed_signal(Z, n_delays)\n",
    "    F = svd(H')\n",
    "    U, S, V = F.U, F.S, F.V\n",
    "\n",
    "    r = min(rank, length(S), size(H, 2))\n",
    "    Vr = @view V[:, 1:r]\n",
    "    Vminus = @view Vr[1:end-1, :]\n",
    "    Vplus = @view Vr[2:end, :]\n",
    "\n",
    "    A_reduced = ((Vminus' * Vminus + ridge * I(r)) \\ (Vminus' * Vplus))'\n",
    "\n",
    "    Ur = @view U[:, 1:r]\n",
    "    Sr = S[1:r]\n",
    "    A_full = Matrix(Ur * Diagonal(Sr) * A_reduced * Diagonal(1.0 ./ Sr) * Ur')\n",
    "\n",
    "    return A_reduced, A_full\n",
    "end\n",
    "\n",
    "function block_norms(A_full, n_features, n_delays)\n",
    "    [norm(@view A_full[1:n_features, (i - 1) * n_features + 1:i * n_features]) for i in 1:n_delays]\n",
    "end\n",
    "\n",
    "function memory_metrics(A_full, n_features, n_delays)\n",
    "    blocks = block_norms(A_full, n_features, n_delays)\n",
    "    weights = blocks ./ max(sum(blocks), 1e-12)\n",
    "    lags = collect(0:n_delays - 1)\n",
    "    memory_centroid = sum(weights .* lags)\n",
    "    recent_fraction = weights[1]\n",
    "    long_lag_fraction = sum(weights[min(end, 6):end])\n",
    "    return memory_centroid, recent_fraction, long_lag_fraction\n",
    "end\n",
    "\n",
    "function departure_from_normality(A)\n",
    "    # return opnorm(A' * A - A * A', 2) / max(opnorm(A, 2)^2, 1e-12)\n",
    "    henrici = sqrt(abs.(norm(A)^2 - sum(abs2, eigvals(A))))\n",
    "    return henrici\n",
    "end \n",
    "\n",
    "function transient_gain(A; horizon=GAIN_HORIZON)\n",
    "    gain = 0.0\n",
    "    Ak = Matrix{Float64}(I, size(A, 1), size(A, 2))\n",
    "    for _ in 1:horizon\n",
    "        Ak = Ak * A\n",
    "        gain = max(gain, opnorm(Ak, 2))\n",
    "    end\n",
    "    return gain\n",
    "end\n",
    "\n",
    "function trial_group(subject, metadata_label)\n",
    "    startswith(subject, \"ST\") && return metadata_label\n",
    "    startswith(subject, \"AB\") && return \"AB\"\n",
    "    return \"YA\"\n",
    "end\n",
    "\n",
    "function analyze_human_trials(data_path, metadata_path; n_delays=N_DELAYS, rank=HANKEL_RANK)\n",
    "    data = load_npy_float64(data_path)\n",
    "    metadata = load_metadata(metadata_path)\n",
    "\n",
    "    subjects = metadata[\"subject\"]\n",
    "    speeds = parse.(Float64, metadata[\"speed\"])\n",
    "    classes = [trial_group(subjects[i], metadata[\"lf_or_hf\"][i]) for i in eachindex(subjects)]\n",
    "\n",
    "    rows = NamedTuple[]\n",
    "    for i in eachindex(subjects)\n",
    "        A_reduced, A_full = fit_hankel_dmd(@view(data[i, :, :]); n_delays=n_delays, rank=rank)\n",
    "        memory_centroid, recent_fraction, long_lag_fraction = memory_metrics(A_full, size(data, 3), n_delays)\n",
    "        push!(\n",
    "            rows,\n",
    "            (\n",
    "                subject = subjects[i],\n",
    "                group = classes[i],\n",
    "                speed = speeds[i],\n",
    "                departure = departure_from_normality(A_reduced),\n",
    "                gain = transient_gain(A_reduced),\n",
    "                memory_centroid = memory_centroid,\n",
    "                recent_fraction = recent_fraction,\n",
    "                long_lag_fraction = long_lag_fraction,\n",
    "            ),\n",
    "        )\n",
    "    end\n",
    "\n",
    "    return rows\n",
    "end\n",
    "\n",
    "function summarize_groups(rows)\n",
    "    summary = NamedTuple[]\n",
    "    for group in (\"YA\", \"AB\", \"HF\", \"LF\")\n",
    "        idxs = findall(r -> r.group == group, rows)\n",
    "        speeds = [rows[i].speed for i in idxs]\n",
    "        departure = [rows[i].departure for i in idxs]\n",
    "        gain = [rows[i].gain for i in idxs]\n",
    "        memory = [rows[i].memory_centroid for i in idxs]\n",
    "        recent = [rows[i].recent_fraction for i in idxs]\n",
    "        longlag = [rows[i].long_lag_fraction for i in idxs]\n",
    "\n",
    "        push!(\n",
    "            summary,\n",
    "            (\n",
    "                group = group,\n",
    "                n = length(idxs),\n",
    "                median_speed = median1(speeds),\n",
    "                median_departure = median1(departure),\n",
    "                median_gain = median1(gain),\n",
    "                median_memory = median1(memory),\n",
    "                median_recent = median1(recent),\n",
    "                median_longlag = median1(longlag),\n",
    "                corr_speed_departure = pearson(speeds, departure),\n",
    "                corr_speed_gain = pearson(speeds, gain),\n",
    "                corr_speed_memory = pearson(speeds, memory),\n",
    "            ),\n",
    "        )\n",
    "    end\n",
    "    return summary\n",
    "end\n",
    "\n",
    "function markdown_table(headers, body_rows)\n",
    "    lines = String[]\n",
    "    push!(lines, \"| \" * join(headers, \" | \") * \" |\")\n",
    "    push!(lines, \"| \" * join(fill(\"---\", length(headers)), \" | \") * \" |\")\n",
    "    for row in body_rows\n",
    "        push!(lines, \"| \" * join(row, \" | \") * \" |\")\n",
    "    end\n",
    "    return join(lines, \"\\n\") * \"\\n\"\n",
    "end\n",
    "\n",
    "function format_fixed(x; digits=3)\n",
    "    return string(round(x; digits=digits))\n",
    "end\n",
    "\n",
    "function group_summary_table(summary)\n",
    "    headers = [\n",
    "        \"Group\",\n",
    "        \"Trials\",\n",
    "        \"Median Speed\",\n",
    "        \"Median Departure\",\n",
    "        \"Median 10-Step Gain\",\n",
    "        \"Memory Centroid (lag samples)\",\n",
    "        \"Long-Lag Fraction\",\n",
    "    ]\n",
    "    rows = [\n",
    "        [\n",
    "            row.group,\n",
    "            string(row.n),\n",
    "            format_fixed(row.median_speed; digits=1),\n",
    "            format_fixed(row.median_departure; digits=4),\n",
    "            format_fixed(row.median_gain; digits=4),\n",
    "            format_fixed(row.median_memory; digits=2),\n",
    "            format_fixed(row.median_longlag; digits=4),\n",
    "        ] for row in summary\n",
    "    ]\n",
    "    return markdown_table(headers, rows)\n",
    "end\n",
    "\n",
    "function coupling_table(summary)\n",
    "    headers = [\n",
    "        \"Group\",\n",
    "        \"corr(speed, departure)\",\n",
    "        \"corr(speed, gain)\",\n",
    "        \"corr(speed, memory centroid)\",\n",
    "    ]\n",
    "    rows = [\n",
    "        [\n",
    "            row.group,\n",
    "            format_fixed(row.corr_speed_departure; digits=4),\n",
    "            format_fixed(row.corr_speed_gain; digits=4),\n",
    "            format_fixed(row.corr_speed_memory; digits=4),\n",
    "        ] for row in summary\n",
    "    ]\n",
    "    return markdown_table(headers, rows)\n",
    "end\n",
    "\n",
    "human_trials = analyze_human_trials(HUMAN_DATA_PATH, HUMAN_METADATA_PATH)\n",
    "human_summary = summarize_groups(human_trials)"
   ]
